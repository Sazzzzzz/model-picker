{
    "name": "model-picker",
    "displayName": "Model Picker",
    "description": "Discover, manage, and configure custom model providers for GitHub Copilot",
    "icon": "assets/model-picker-icon.png",
    "version": "0.1.0",
    "publisher": "Caffein3",
    "author": {
        "name": "Caffein3"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Sazzzzzz/model-picker"
    },
    "keywords": [
        "copilot",
        "model",
        "openrouter",
        "chat",
        "ai",
        "llm",
        "openai"
    ],
    "categories": [
        "AI",
        "Chat"
    ],
    "markdown": "github",
    "engines": {
        "vscode": "^1.109.0"
    },
    "activationEvents": [],
    "main": "./out/extension.js",
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^22.13.14",
        "@types/vscode": "^1.109.0",
        "typescript": "^5.8.2"
    },
    "contributes": {
        "commands": [
            {
                "command": "modelPicker.importModel",
                "title": "%commands.importModel.title%",
                "category": "Model Picker"
            },
            {
                "command": "modelPicker.editModelProvider",
                "title": "%commands.editModelProvider.title%",
                "category": "Model Picker"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "modelPicker.importModel"
                },
                {
                    "command": "modelPicker.editModelProvider"
                }
            ]
        },
        "configuration": {
            "title": "Model Picker",
            "properties": {
                "modelPicker.defaultBaseUrl": {
                    "type": "string",
                    "default": "http://localhost",
                    "description": "%configuration.defaultBaseUrl.description%"
                },
                "modelPicker.defaultMaxInputTokens": {
                    "type": "number",
                    "default": 16000,
                    "description": "%configuration.defaultMaxInputTokens.description%"
                },
                "modelPicker.defaultMaxOutputTokens": {
                    "type": "number",
                    "default": 128000,
                    "description": "%configuration.defaultMaxOutputTokens.description%"
                }
            }
        }
    }
}
